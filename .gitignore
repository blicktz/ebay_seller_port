# eBay Seller Analytics - Git Ignore

# ============================================================================
# Sensitive Data - NEVER COMMIT
# ============================================================================

# Environment variables with secrets
.env

# Database files (contains your data)
*.db
*.db-journal
*.db-wal
*.db-shm
data/*.db

# Generated reports (may contain sensitive business data)
reports/*.csv
!reports/.gitkeep

# ============================================================================
# Python
# ============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

