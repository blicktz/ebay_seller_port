# eBay Seller Analytics Configuration
# Copy this file to .env and replace placeholders with your actual values

# ==============================================================================
# REQUIRED: eBay API Authentication
# ==============================================================================

# Your eBay Production User Access Token
# Get this from: https://developer.ebay.com/my/auth/
# This is REQUIRED for all API calls
EBAY_ACCESS_TOKEN=your_production_access_token_here

# ==============================================================================
# Marketplace Configuration
# ==============================================================================

# eBay Marketplace ID (default: EBAY_US)
# Supported values: EBAY_US, EBAY_GB, EBAY_DE, EBAY_FR, EBAY_ES, EBAY_IT, EBAY_AU, EBAY_MOTORS_US
EBAY_MARKETPLACE_ID=EBAY_US

# ==============================================================================
# Database Configuration
# ==============================================================================

# Path to SQLite database file (default: data/ebay_analytics.db)
DB_PATH=data/ebay_analytics.db

# ==============================================================================
# Sold Listings Configuration
# ==============================================================================

# Number of days to look back for sold items (default: 90, max: 90)
# Analytics API only retains traffic data for sold listings for 90 days
SOLD_ITEMS_LOOKBACK_DAYS=90

# Enable/disable sold items syncing (default: true)
# Set to false to only sync active listings
SYNC_SOLD_ITEMS_ENABLED=true

# ==============================================================================
# Optional: Default Date Ranges
# ==============================================================================

# Default start date in YYYYMMDD format (optional)
# If not set, will use 7 days ago
# DEFAULT_START_DATE=20260218

# Default end date in YYYYMMDD format (optional)
# If not set, will use today
# DEFAULT_END_DATE=20260225

# ==============================================================================
# Optional: API Rate Limiting & Retry Configuration
# ==============================================================================

# Maximum number of retry attempts for failed API calls (default: 3)
API_MAX_RETRIES=3

# Delay between retry attempts in seconds (default: 2.0)
API_RETRY_DELAY=2.0

# API request timeout in seconds (default: 30)
API_TIMEOUT=30

# ==============================================================================
# Optional: Batching Configuration
# ==============================================================================

# Batch size for sold items queries (default: 200, max: 200)
# Analytics API supports max 200 listing IDs per request
SOLD_ITEMS_BATCH_SIZE=200

# ==============================================================================
# DVD Listing Automation Configuration
# ==============================================================================

# Path to DVD catalog database (default: data/dvd_catalog.db)
DVD_DB_PATH=data/dvd_catalog.db

# Number of UPCs to batch per Catalog API request (default: 20, recommended: 10-20)
# Higher values mean fewer API calls but may have slower response times
DVD_CATALOG_BATCH_SIZE=20

# Cache expiration period in days (default: 30)
# Cached catalog data older than this will be considered expired
DVD_CACHE_EXPIRY_DAYS=30

# Whether to use catalog cache (default: true)
# Set to false to always fetch fresh data from API
DVD_USE_CACHE=true

# Automatically export results to CSV after lookup (default: false)
DVD_AUTO_EXPORT=false

# Default path for exported CSV files (default: data/dvd_exports)
DVD_EXPORT_PATH=data/dvd_exports

# ==============================================================================
# eBay Draft CSV Generator Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Media Type Selection (turnkey configuration)
# ------------------------------------------------------------------------------
# Set the media type: DVD, CD, or VHS
# This automatically sets defaults for category, template, and other settings
# Individual settings below can override the defaults
MEDIA_TYPE=DVD

# ------------------------------------------------------------------------------
# Common Settings (applies to all media types)
# ------------------------------------------------------------------------------

# Prefix for the Custom label (SKU) generated for each item
SKU_PREFIX=E-0313-

# Starting number for the SKU sequence (will increment for each item)
START_COUNT=1

# Condition ID of the items (e.g., 1000 for Brand New)
EBAY_CONDITION_ID=1000

# Schedule Date (days ahead)
SCHEDULE_DAYS_AHEAD=21

# Default Placeholder Price
PLACEHOLDER_PRICE=99.99

# Placeholder Image URL for products with missing or inadequate images
# Must be at least 500x500 pixels to meet eBay's requirements
# Leave empty to use products' original images even if they don't meet requirements
#
# Options for getting a placeholder image:
#   1. Create a 600x600 gray image and upload to Imgur (https://imgur.com/upload)
#   2. Use your own website/server to host the placeholder
#   3. Use eBay's stock images (if available for your products)
#
# Example: PLACEHOLDER_IMAGE_URL=https://i.imgur.com/yourplaceholder.jpg
PLACEHOLDER_IMAGE_URL=

# Postal Code
POSTAL_CODE=94043

# Payment and Return Policies (shared across media types)
PAYMENT_POLICY="eBay Managed Payments (281844116014)"
RETURN_POLICY="Free return within 30d"

# ------------------------------------------------------------------------------
# DVD-Specific Defaults
# ------------------------------------------------------------------------------
# These are auto-applied when MEDIA_TYPE=DVD
# Override by uncommenting and setting below
DVD_CATEGORY_ID=617
DVD_TEMPLATE_PATH=docs/eBay-DVD-template.csv
DVD_DESCRIPTION_TEMPLATE="Brand New and Sealed DVD."
DVD_REGION_CODE="DVD: 1 (US, Canada...)"
DVD_SHIPPING_POLICY="Single DVD/VHS -Free Shipping"
DVD_WEIGHT_MAJOR=0
DVD_WEIGHT_MINOR=4
DVD_PACKAGE_LENGTH=7
DVD_PACKAGE_WIDTH=5
DVD_PACKAGE_DEPTH=1
DVD_PACKAGE_TYPE=PackageThickEnvelope

# ------------------------------------------------------------------------------
# CD-Specific Defaults
# ------------------------------------------------------------------------------
# These are auto-applied when MEDIA_TYPE=CD
# Override by uncommenting and setting below
CD_CATEGORY_ID=176984
CD_TEMPLATE_PATH=docs/eBay-CD-template.csv
CD_DESCRIPTION_TEMPLATE="Brand New and Sealed CD."
CD_SHIPPING_POLICY="Single CD - Free Shipping"
CD_WEIGHT_MAJOR=0
CD_WEIGHT_MINOR=3
CD_PACKAGE_LENGTH=6
CD_PACKAGE_WIDTH=5
CD_PACKAGE_DEPTH=0.5
CD_PACKAGE_TYPE=PackageThickEnvelope

# ------------------------------------------------------------------------------
# VHS-Specific Defaults
# ------------------------------------------------------------------------------
# These are auto-applied when MEDIA_TYPE=VHS
# Override by uncommenting and setting below
VHS_CATEGORY_ID=309
VHS_TEMPLATE_PATH=docs/eBay-VHS-template.csv
VHS_DESCRIPTION_TEMPLATE="VHS Tape in Good Condition."
VHS_SHIPPING_POLICY="Single DVD/VHS -Free Shipping"
VHS_WEIGHT_MAJOR=0
VHS_WEIGHT_MINOR=8
VHS_PACKAGE_LENGTH=8
VHS_PACKAGE_WIDTH=4.5
VHS_PACKAGE_DEPTH=1
VHS_PACKAGE_TYPE=PackageThickEnvelope

# ------------------------------------------------------------------------------
# Manual Overrides (Optional)
# ------------------------------------------------------------------------------
# Uncomment any of these to override the media-type-specific defaults

# EBAY_CATEGORY_ID=617
# TEMPLATE_PATH=docs/eBay-DVD-template.csv
# EBAY_DESCRIPTION_TEMPLATE="Brand New and Sealed DVD."
# REGION_CODE="DVD: 1 (US, Canada...)"
# SHIPPING_POLICY="Single DVD/VHS -Free Shipping"
# DEFAULT_WEIGHT_MAJOR=0
# DEFAULT_WEIGHT_MINOR=4
# DEFAULT_PACKAGE_LENGTH=7
# DEFAULT_PACKAGE_WIDTH=5
# DEFAULT_PACKAGE_DEPTH=1
# DEFAULT_PACKAGE_TYPE=PackageThickEnvelope
